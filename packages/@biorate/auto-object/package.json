{
  "name": "@biorate/auto-object",
  "version": "1.146.0",
  "description": "Auto object",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/auto-object"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "Axios"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/tools": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "lodash": "4.17.21"
  },
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
