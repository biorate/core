{
  "name": "@biorate/react-virtual-table",
  "version": "3.2.1",
  "description": "React virtual table",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:bundle": "npx webpack --config=../../../webpack.config.js --mode=production --entry=./index.ts -o ./dist",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:bundle && pnpm run build:types",
    "demo": "npx webpack --config=../../../webpack.config.js --mode=production --entry=./demo/index.tsx --entry=./demo/index.pug --entry=./demo/index.less -o ./../../../docs/demo/@biorate/react-virtual-table",
    "demo:dev": "npx webpack serve --config=../../../webpack.config.js --mode=development --entry=./demo/index.tsx --entry=./demo/index.pug --entry=./demo/index.less -o ./dist",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "stylelint": "stylelint \"src/**/*.less\" \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.less\" \"src/**/*.css\" --fix",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/react-virtual-table"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "react",
    "virtual",
    "table",
    "virtual-table"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.2"
  },
  "devDependencies": {
    "@biorate/collection": "workspace:*",
    "@types/react": "^16.8.0",
    "mobx": "^5.15.7",
    "mobx-react": "^6.3.1",
    "react": "^16.8.0",
    "react-dom": "^16.8.0"
  },
  "gitHead": "366894dafd47b9613acde338a5615ee547f729a8"
}
