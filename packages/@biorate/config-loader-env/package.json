{
  "name": "@biorate/config-loader-env",
  "version": "1.161.0",
  "description": "Config loader for ENV's config",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "cross-env TEST_ENV=test npx vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/config-loader-env"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "dependencies": {
    "@biorate/config": "workspace:*",
    "@biorate/config-loader": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "@dotenvx/dotenvx": "^1.51.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  },
  "gitHead": "fdd6dbd61368f7a9f9deb3b72243b19ecb3767a6",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
