{
  "name": "@biorate/sequelize",
  "version": "1.159.0",
  "description": "Sequelize ORM connector",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/sequelize"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "sequelize",
    "connector"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "sequelize": "6.37.3",
    "sequelize-typescript": "2.1.6"
  },
  "dependencies": {
    "@biorate/config": "workspace:*",
    "@biorate/connector": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*"
  },
  "devDependencies": {
    "sqlite3": "5.0.7"
  },
  "gitHead": "fdd6dbd61368f7a9f9deb3b72243b19ecb3767a6",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
