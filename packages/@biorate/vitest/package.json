{
  "name": "@biorate/vitest",
  "version": "1.4.0",
  "description": "OOP test decorators for vitest with Allure support",
  "main": "./dist/cjs/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "vitest",
    "oop",
    "decorators",
    "allure",
    "testing"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "allure-js-commons": ">=3.2.0",
    "allure-vitest": ">=3.2.0",
    "reflect-metadata": ">=0.2.2",
    "vitest": ">=2.0.0"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/run-context": "workspace:*",
    "@biorate/symbolic": "workspace:*",
    "@biorate/tools": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
