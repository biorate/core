{
  "name": "@biorate/axios",
  "version": "2.2.3",
  "description": "Axios OOP static interface",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/axios"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "Axios"
  ],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "fdd6dbd61368f7a9f9deb3b72243b19ecb3767a6",
  "dependencies": {
    "@biorate/singleton": "workspace:*",
    "axios": "1.15.1",
    "axios-retry": "4.5.0",
    "http-status": "2.1.0",
    "lodash": "4.17.23",
    "path-to-url": "0.1.0"
  },
  "devDependencies": {
    "@biorate/config": "workspace:*",
    "@biorate/inversion": "workspace:*"
  }
}
