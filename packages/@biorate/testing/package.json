{
  "name": "@biorate/testing",
  "version": "1.0.0",
  "description": "Test harness, connector profiles and in-memory mocks for Biorate applications",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./vitest": {
      "types": "./dist/types/vitest.d.ts",
      "import": "./dist/esm/vitest.js",
      "require": "./dist/cjs/vitest.js",
      "default": "./dist/cjs/vitest.js"
    },
    "./memory/pg": {
      "types": "./dist/types/src/memory/pg/index.d.ts",
      "import": "./dist/esm/src/memory/pg/index.js",
      "require": "./dist/cjs/src/memory/pg/index.js",
      "default": "./dist/cjs/src/memory/pg/index.js"
    },
    "./memory/redis": {
      "types": "./dist/types/src/memory/redis/index.d.ts",
      "import": "./dist/esm/src/memory/redis/index.js",
      "require": "./dist/cjs/src/memory/redis/index.js",
      "default": "./dist/cjs/src/memory/redis/index.js"
    },
    "./memory/kafkajs": {
      "types": "./dist/types/src/memory/kafkajs/index.d.ts",
      "import": "./dist/esm/src/memory/kafkajs/index.js",
      "require": "./dist/cjs/src/memory/kafkajs/index.js",
      "default": "./dist/cjs/src/memory/kafkajs/index.js"
    },
    "./memory/amqp": {
      "types": "./dist/types/src/memory/amqp/index.d.ts",
      "import": "./dist/esm/src/memory/amqp/index.js",
      "require": "./dist/cjs/src/memory/amqp/index.js",
      "default": "./dist/cjs/src/memory/amqp/index.js"
    },
    "./memory/ioredis": {
      "types": "./dist/types/src/memory/ioredis/index.d.ts",
      "import": "./dist/esm/src/memory/ioredis/index.js",
      "require": "./dist/cjs/src/memory/ioredis/index.js",
      "default": "./dist/cjs/src/memory/ioredis/index.js"
    },
    "./memory/mssql": {
      "types": "./dist/types/src/memory/mssql/index.d.ts",
      "import": "./dist/esm/src/memory/mssql/index.js",
      "require": "./dist/cjs/src/memory/mssql/index.js",
      "default": "./dist/cjs/src/memory/mssql/index.js"
    },
    "./memory/clickhouse": {
      "types": "./dist/types/src/memory/clickhouse/index.d.ts",
      "import": "./dist/esm/src/memory/clickhouse/index.js",
      "require": "./dist/cjs/src/memory/clickhouse/index.js",
      "default": "./dist/cjs/src/memory/clickhouse/index.js"
    },
    "./memory/minio": {
      "types": "./dist/types/src/memory/minio/index.d.ts",
      "import": "./dist/esm/src/memory/minio/index.js",
      "require": "./dist/cjs/src/memory/minio/index.js",
      "default": "./dist/cjs/src/memory/minio/index.js"
    },
    "./memory/vault": {
      "types": "./dist/types/src/memory/vault/index.d.ts",
      "import": "./dist/esm/src/memory/vault/index.js",
      "require": "./dist/cjs/src/memory/vault/index.js",
      "default": "./dist/cjs/src/memory/vault/index.js"
    },
    "./memory/opensearch": {
      "types": "./dist/types/src/memory/opensearch/index.d.ts",
      "import": "./dist/esm/src/memory/opensearch/index.js",
      "require": "./dist/cjs/src/memory/opensearch/index.js",
      "default": "./dist/cjs/src/memory/opensearch/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/testing"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "testing",
    "vitest",
    "connector",
    "mock"
  ],
  "author": "llevkin",
  "license": "MIT",
  "dependencies": {
    "@biorate/amqp": "workspace:*",
    "@biorate/clickhouse": "workspace:*",
    "@biorate/config": "workspace:*",
    "@biorate/connector": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "@biorate/ioredis": "workspace:*",
    "@biorate/kafkajs": "workspace:*",
    "@biorate/minio": "workspace:*",
    "@biorate/mongodb": "workspace:*",
    "@biorate/mssql": "workspace:*",
    "@biorate/opensearch": "workspace:*",
    "@biorate/pg": "workspace:*",
    "@biorate/rdkafka": "workspace:*",
    "@biorate/redis": "workspace:*",
    "@biorate/sequelize": "workspace:*",
    "@biorate/vault": "workspace:*",
    "inversify": "5.1.1"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/amqplib": "0.10.5",
    "amqp-connection-manager": "4.1.14",
    "amqplib": "0.10.3",
    "kafkajs": "^2.2.3",
    "vitest": "^4.0.18"
  }
}
