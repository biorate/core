{
  "name": "@biorate/nestjs-tools",
  "version": "2.2.2",
  "description": "NestJS tools",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/nestjs-tools"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "daa33b049c366a21030eb5cfae0fe3148f60693a",
  "peerDependencies": {
    "@nestjs/common": ">=10.4.15",
    "@nestjs/core": ">=10.4.15",
    "@nestjs/swagger": ">=8.1.0",
    "class-validator": ">=0.14.0",
    "express": ">=4.21.2",
    "http-proxy": ">=1.18.1",
    "http-proxy-middleware": "=2.0.6",
    "lodash-es": ">=4.17.21",
    "rxjs": ">=7.8.2",
    "ws": ">=8.18.0"
  },
  "dependencies": {
    "@biorate/axios": "^3.3.0",
    "@biorate/config": "^3.2.0",
    "@biorate/errors": "^3.1.0",
    "@biorate/inversion": "^3.1.0",
    "@biorate/opentelemetry": "^2.2.0",
    "@biorate/prometheus": "^3.1.0",
    "@biorate/tools": "^3.1.0",
    "http-proxy": "1.18.1",
    "http-proxy-middleware": "2.0.6",
    "json-stringify-safe": "5.0.1",
    "on-headers": "1.0.2"
  },
  "devDependencies": {
    "@types/json-stringify-safe": "5.0.3"
  }
}
