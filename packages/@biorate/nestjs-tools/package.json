{
  "name": "@biorate/nestjs-tools",
  "version": "1.169.1",
  "description": "NestJS tools",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/nestjs-tools"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": ">=10.4.15",
    "@nestjs/core": ">=10.4.15",
    "@nestjs/swagger": ">=8.1.0",
    "class-validator": ">=0.14.0",
    "express": ">=4.21.2",
    "http-proxy": ">=1.18.1",
    "http-proxy-middleware": "=2.0.6",
    "lodash": ">=4.17.21",
    "rxjs": ">=7.8.2",
    "ws": ">=8.18.0"
  },
  "dependencies": {
    "@biorate/axios": "workspace:*",
    "@biorate/config": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "@biorate/opentelemetry": "workspace:*",
    "@biorate/prometheus": "workspace:*",
    "@biorate/tools": "workspace:*",
    "http-proxy": "1.18.1",
    "http-proxy-middleware": "2.0.6",
    "json-stringify-safe": "5.0.1",
    "on-headers": "1.0.2"
  },
  "gitHead": "844476bb73750f0219545e7d95d259105db46e71",
  "devDependencies": {
    "@types/json-stringify-safe": "5.0.3"
  },
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
