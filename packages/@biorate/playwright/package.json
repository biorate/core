{
  "name": "@biorate/playwright",
  "version": "1.164.2",
  "description": "OOP test decorators for playwright",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx playwright test",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/playwright"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "@playwright/test": ">=1.44.0",
    "allure-js-commons": ">=3.2.0",
    "allure-playwright": ">=2.10.0",
    "playwright": ">=1.44.0",
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/run-context": "workspace:*",
    "@biorate/symbolic": "workspace:*",
    "@biorate/tools": "workspace:*"
  },
  "gitHead": "b9ab225c32dfebaf6dc8a9d750a1421ac62307cd",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
