{
  "name": "@biorate/playwright",
  "version": "1.165.0",
  "description": "OOP test decorators for playwright",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "node ../../../.scripts/write-package-type.js dist/esm module",
    "test": "npx playwright test",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/playwright"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "b9ab225c32dfebaf6dc8a9d750a1421ac62307cd",
  "peerDependencies": {
    "@playwright/test": ">=1.44.0",
    "allure-js-commons": ">=3.2.0",
    "allure-playwright": ">=2.10.0",
    "playwright": ">=1.44.0",
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/run-context": "workspace:*",
    "@biorate/symbolic": "workspace:*",
    "@biorate/tools": "workspace:*"
  }
}
