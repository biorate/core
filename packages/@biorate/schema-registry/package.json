{
  "name": "@biorate/schema-registry",
  "version": "2.2.3",
  "description": "Schema registry connector",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/schema-registry"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "schema registry",
    "confluent",
    "kafka",
    "connector"
  ],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "bbe8f224bd98940a0cd27d33e01f977180c1d76d",
  "dependencies": {
    "@biorate/axios-prometheus": "workspace:*",
    "@biorate/config": "workspace:*",
    "@biorate/connector": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "avsc": "^5.7.4"
  }
}
