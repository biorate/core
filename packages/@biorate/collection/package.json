{
  "name": "@biorate/collection",
  "version": "2.2.0",
  "description": "Collection",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/collection"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "collection",
    "map",
    "index",
    "multi-index",
    "observable",
    "di",
    "ioc",
    "structure",
    "library"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/symbolic": "workspace:*",
    "@biorate/tools": "workspace:*",
    "lodash": "^4.17.21",
    "luxon": "^1.27.0",
    "mobx": "^5.15.7"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.169",
    "@types/luxon": "^1.26.5"
  },
  "gitHead": "366894dafd47b9613acde338a5615ee547f729a8",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
