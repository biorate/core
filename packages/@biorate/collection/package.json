{
  "name": "@biorate/collection",
  "version": "3.2.1",
  "description": "Collection",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/collection"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "collection",
    "map",
    "index",
    "multi-index",
    "observable",
    "di",
    "ioc",
    "structure",
    "library"
  ],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "366894dafd47b9613acde338a5615ee547f729a8",
  "peerDependencies": {
    "lodash-es": ">=4.17.21",
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/symbolic": "workspace:*",
    "@biorate/tools": "workspace:*",
    "luxon": "^1.27.0",
    "mobx": "^5.15.7"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^1.26.5"
  }
}
