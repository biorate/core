{
  "name": "@biorate/mongodb",
  "version": "1.159.2",
  "description": "Mongodb ORM connector based on mongoose and typegoose",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "node ../../../.scripts/write-package-type.js dist/esm module",
    "test": "npx nyc --nycrc-path ../../../.nycrc.json -- npx mocha tests/**/*.spec.ts",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/mongodb"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "mongodb",
    "connector"
  ],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "fdd6dbd61368f7a9f9deb3b72243b19ecb3767a6",
  "dependencies": {
    "@biorate/config": "workspace:*",
    "@biorate/connector": "workspace:*",
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "@biorate/tools": "workspace:*",
    "@typegoose/typegoose": "^11.0.2",
    "mongodb": "^5.9.1",
    "mongoose": "^7.0.4"
  }
}
