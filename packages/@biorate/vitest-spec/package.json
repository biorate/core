{
  "name": "@biorate/vitest-spec",
  "version": "2.0.2",
  "description": "Vitest Spec abstract helper class",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npx vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/vitest-spec"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "vitest",
    "spec",
    "abstract",
    "helpers"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "class-validator": ">=0.14.1",
    "lodash-es": ">=4.17.21",
    "reflect-metadata": ">=0.1.13",
    "vitest": ">=2.0.0"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/tools": "workspace:*",
    "nock": "14.0.1",
    "supertest": "6.1.6"
  },
  "optionalDependencies": {
    "sinon": "19.0.2"
  },
  "devDependencies": {
    "@biorate/vitest": "workspace:*",
    "@types/supertest": "2.0.11"
  }
}
