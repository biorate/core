{
  "name": "@biorate/vitest-spec",
  "version": "1.3.1",
  "description": "Vitest Spec abstract helper class",
  "main": "./dist/cjs/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx vitest run",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/vitest-spec"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "vitest",
    "spec",
    "abstract",
    "helpers"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "class-validator": ">=0.14.1",
    "vitest": ">=2.0.0"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/node-tools": "workspace:*",
    "@biorate/tools": "workspace:*",
    "lodash": "4.17.21",
    "nock": "14.0.1",
    "supertest": "6.1.6"
  },
  "optionalDependencies": {
    "sinon": "19.0.2"
  },
  "devDependencies": {
    "@biorate/vitest": "workspace:*",
    "@types/supertest": "2.0.11",
    "reflect-metadata": "0.2.2"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
