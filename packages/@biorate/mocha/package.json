{
  "name": "@biorate/mocha",
  "version": "1.141.1",
  "description": "Mocha OOP tests based on @testdeck/core",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx nyc --nycrc-path ../../../.nycrc.json -- npx mocha tests/**/*.spec.ts",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/mocha"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "mocha",
    "OOP",
    "parallel",
    "@testdeck/core"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "mocha": ">=10.2.0",
    "mocha-multi-reporters": ">=1.5.1",
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/run-context": "workspace:*",
    "allure-js-commons": "2.10.0",
    "allure-mocha": "2.10.0",
    "mocha.parallel": "0.15.6"
  },
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
