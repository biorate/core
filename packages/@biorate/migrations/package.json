{
  "name": "@biorate/migrations",
  "version": "2.2.7",
  "description": "Migrations tools",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json && npx tsc-alias -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && npx tsc-alias -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/migrations"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "migrations"
  ],
  "author": "llevkin",
  "license": "MIT",
  "gitHead": "daa33b049c366a21030eb5cfae0fe3148f60693a",
  "dependencies": {
    "@biorate/amqp": "^2.1.3",
    "@biorate/clickhouse": "^2.4.3",
    "@biorate/config": "^3.2.3",
    "@biorate/config-loader": "^2.1.4",
    "@biorate/config-loader-env": "^2.1.4",
    "@biorate/config-loader-fs": "^2.1.4",
    "@biorate/config-loader-vault": "^2.1.4",
    "@biorate/connector": "^3.1.3",
    "@biorate/errors": "^3.1.2",
    "@biorate/inversion": "^3.1.3",
    "@biorate/kafkajs": "^2.2.3",
    "@biorate/minio": "^2.1.3",
    "@biorate/mongodb": "^2.1.3",
    "@biorate/proxy": "^2.1.5",
    "@biorate/schema-registry": "^3.1.6",
    "@biorate/sequelize": "^2.2.3",
    "@biorate/tools": "^3.1.2",
    "@biorate/vault": "^2.2.3"
  }
}
