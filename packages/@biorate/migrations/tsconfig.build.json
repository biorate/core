{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "moduleResolution": "node",
    "incremental": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "paths": {
      "@/require": ["src/require-cjs.ts"]
    }
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "**/*spec.ts"]
}
