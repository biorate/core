{
  "name": "@biorate/opentelemetry",
  "version": "1.169.2",
  "description": "OpenTelemetry integration",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "node ../../../.scripts/write-package-type.js dist/esm module",
    "test": "npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/opentelemetry"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "reflect-metadata": ">=0.1.13"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/masquerade": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.71.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.213.0",
    "@opentelemetry/exporter-prometheus": "0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.213.0",
    "@opentelemetry/otlp-exporter-base": "0.213.0",
    "@opentelemetry/resource-detector-alibaba-cloud": "0.33.3",
    "@opentelemetry/resource-detector-aws": "2.13.0",
    "@opentelemetry/resource-detector-container": "0.8.4",
    "@opentelemetry/resource-detector-gcp": "0.48.0",
    "@opentelemetry/resources": "2.6.0",
    "@opentelemetry/sdk-metrics": "2.6.0",
    "@opentelemetry/sdk-node": "0.213.0",
    "@opentelemetry/sdk-trace-base": "2.6.0",
    "json-stringify-safe": "5.0.1",
    "traverse": "0.6.11"
  },
  "devDependencies": {
    "@types/json-stringify-safe": "5.0.3",
    "@types/traverse": "0.6.37"
  }
}
