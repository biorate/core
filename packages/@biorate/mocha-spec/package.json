{
  "name": "@biorate/mocha-spec",
  "version": "1.142.0",
  "description": "Mocha Spec abstract helper class",
  "main": "./dist/cjs/index.js",
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "test": "npx nyc --nycrc-path ../../../.nycrc.json -- npx mocha tests/**/*.spec.ts",
    "prepublishOnly": "pnpm run build",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json && node ../../../scripts/rename-esm-to-mjs.mjs",
    "build:types": "npx tsc -p ./tsconfig.build.types.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/mocha-spec"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "mocha",
    "spec",
    "abstract",
    "helpers"
  ],
  "author": "llevkin",
  "license": "MIT",
  "peerDependencies": {
    "class-validator": ">=0.14.1"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/mocha": "workspace:*",
    "@biorate/node-tools": "workspace:*",
    "@biorate/tools": "workspace:*",
    "chai": "6.2.2",
    "mocha-chai-jest-snapshot": "1.1.7",
    "nock": "14.0.1",
    "sinon": "19.0.2",
    "supertest": "6.1.6"
  },
  "devDependencies": {
    "@types/sinon": "17.0.4",
    "@types/supertest": "2.0.11"
  },
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
