{
  "name": "@biorate/unimock",
  "version": "1.1.0",
  "description": "Snapshot-based proxy mocking for connectors and services",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./vitest/setup": {
      "types": "./dist/types/src/vitest/setup.d.ts",
      "import": "./dist/esm/src/vitest/setup.js",
      "require": "./dist/cjs/src/vitest/setup.js",
      "default": "./dist/cjs/src/vitest/setup.js"
    },
    "./vitest": {
      "types": "./dist/types/src/vitest/index.d.ts",
      "import": "./dist/esm/src/vitest/index.js",
      "require": "./dist/cjs/src/vitest/index.js",
      "default": "./dist/cjs/src/vitest/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "cleanup dist",
    "build:cjs": "npx tsc -p ./tsconfig.build.cjs.json",
    "build:esm": "npx tsc -p ./tsconfig.build.esm.json",
    "build:types": "npx tsc -p ./tsconfig.build.types.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "postbuild:cjs": "node ../../../.scripts/write-package-type.js dist/cjs commonjs",
    "postbuild:esm": "tsc-esm-fix --tsconfig=./tsconfig.build.esm.json --target=./dist/esm && node ../../../.scripts/write-package-type.js dist/esm module",
    "format": "prettier --check src",
    "lint": "eslint src --ext .ts",
    "format:fix": "prettier --write src",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "pnpm run test:replay",
    "test:replay": "UNIMOCK=replay npx vitest run --coverage",
    "test:record": "UNIMOCK_STRIP_REQUEST=1 UNIMOCK_SKIP_CONN_ARGS=1 UNIMOCK_GZIP=1 UNIMOCK=record npx vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biorate/core.git",
    "directory": "packages/@biorate/unimock"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://biorate.github.io/core",
  "keywords": [
    "mock",
    "snapshot",
    "e2e",
    "connector"
  ],
  "author": "llevkin",
  "license": "MIT",
  "devDependencies": {
    "@biorate/clickhouse": "workspace:*",
    "@biorate/config": "workspace:*",
    "@biorate/ioredis": "workspace:*",
    "@biorate/mongodb": "workspace:*",
    "@biorate/mssql": "workspace:*",
    "@biorate/opensearch": "workspace:*",
    "@biorate/pg": "workspace:*",
    "@biorate/prometheus": "workspace:*",
    "@biorate/proxy": "workspace:*",
    "@biorate/proxy-prometheus": "workspace:*",
    "@biorate/rdkafka": "workspace:*",
    "@biorate/redis": "workspace:*",
    "@biorate/schema-registry": "workspace:*",
    "@biorate/sequelize": "workspace:*",
    "@biorate/tools": "workspace:*",
    "@confluentinc/kafka-javascript": "latest",
    "@types/lodash": "^4.14.173",
    "pg": "^8.20.0"
  },
  "dependencies": {
    "@biorate/errors": "workspace:*",
    "@biorate/inversion": "workspace:*",
    "@biorate/lifecycled": "workspace:*",
    "lodash": "^4.17.21"
  }
}
